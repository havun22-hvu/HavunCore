{
    // Infection PHP — kritieke-paden-config. Breder dan infection.json5
    // zodat Vault (Controller + Models) en Auth/Middleware files mee
    // genomen worden. Gebruik: `vendor/bin/infection --configuration=infection-critical-paths.json5 --filter=<file>`.
    "$schema": "vendor/infection/infection/resources/schema.json",
    "source": {
        "directories": [
            "app/Services",
            "app/Http/Controllers/Api",
            "app/Http/Middleware",
            "app/Models",
            "app/Console"
        ],
        "excludes": [
            "Chaos",
            "DocIntelligence"
        ]
    },
    "timeout": 30,
    "logs": {
        "text": "storage/logs/infection-critical.log",
        "summary": "storage/logs/infection-critical-summary.log",
        "perMutator": "storage/logs/infection-critical-per-mutator.md",
        "github": true
    },
    "tmpDir": "storage/framework/cache/infection-critical",
    "phpUnit": {
        "configDir": ".",
        "customPath": "vendor/bin/phpunit"
    },
    // Zie `infection.json5` voor ratio-nale; deze config volgt dezelfde
    // drempel zodat beide runs consistent regressies pakken.
    "minMsi": 60,
    "minCoveredMsi": 60,
    "mutators": {
        "@default": true,
        "global-ignoreSourceCodeByRegex": [
            "Log::.*",
            "report\\(.*\\)"
        ],
        // Per-service ignores voor mutaties die nooit door tests killable zijn
        // op SQLite/zonder externe mocks. Niet om coverage te padden — alleen
        // voor false-positives waar bewijs van correctheid elders zit.
        "IncrementInteger": {
            "ignore": [
                // ->timeout(60) — Http::fake honoreert geen timeouts.
                // Cache::put(..., 60) TTL — niet testbaar zonder 60s wait.
                "App\\Services\\AIProxyService::chat",
                "App\\Services\\AIProxyService::checkRateLimit",
                "App\\Services\\AIProxyService::logUsage",
                // round($t * 1000) — sub-ms verschil, CI-jitter unstable.
                "App\\Services\\AIProxyService::getUsageStats",
                // SQLite COUNT() retourneert nooit null, dus `?? 0` triggert
                // niet — Inc/Dec van die default invisible. MySQL covered.
                // Cache::remember TTL — zelfde reden als AIProxy.
                "App\\Services\\ObservabilityService::getDashboard",
                "App\\Services\\ObservabilityService::getQualityFindings"
            ]
        },
        "DecrementInteger": {
            "ignore": [
                "App\\Services\\AIProxyService::chat",
                "App\\Services\\AIProxyService::checkRateLimit",
                "App\\Services\\AIProxyService::logUsage",
                "App\\Services\\AIProxyService::getUsageStats",
                "App\\Services\\ObservabilityService::getDashboard",
                "App\\Services\\ObservabilityService::getQualityFindings"
            ]
        },
        "RoundingFamily": {
            "ignore": [
                // round($t * 1000) op execution-time — sub-ms verschil tussen
                // round/floor/ceil onbetrouwbaar in CI.
                "App\\Services\\AIProxyService::chat",
                "App\\Services\\AIProxyService::logUsage",
                "App\\Services\\AIProxyService::getUsageStats",
                // round($disk / 1024 / 1024 / 1024, 2) — env-afhankelijke
                // byte-counts (Linux-CI vs Windows-lokaal). MySQL-job dekt
                // de DB-bound mutators op 100% MSI.
                "App\\Services\\ObservabilityService::getSystemHealth"
            ]
        },
        "CastInt": {
            "ignore": [
                // SQLite returnt SUM/COUNT al als int; cast verwijderen heeft
                // geen effect zonder strict type-check. AIProxy MySQL-job
                // (aiproxy-mysql-msi) dekt deze op 100% MSI met mysqlnd's
                // string-coercion. Observability heeft dezelfde categorie.
                "App\\Services\\AIProxyService::getUsageStats",
                "App\\Services\\AIProxyService::logUsage",
                "App\\Services\\ObservabilityService::getDashboard",
                "App\\Services\\ObservabilityService::getQualityFindings"
            ]
        },
        "CastString": {
            "ignore": [
                // (string) config(...) — config returnt al string default;
                // verwijderen heeft geen effect zonder strict type-check.
                "App\\Services\\ObservabilityService::getQualityFindings"
            ]
        },
        "Coalesce": {
            "ignore": [
                // `0 ?? $val` of `$message ?? $title ?? ''` — semantisch
                // identiek omdat de eerste operand altijd niet-null is in de
                // test-fixtures. Geen functionele regressie.
                "App\\Services\\ObservabilityService::getDashboard",
                "App\\Services\\ObservabilityService::getQualityFindings"
            ]
        },
        "ArrayItem": {
            "ignore": [
                // `=>` → `>` is een parser-niveau syntax mutator die het
                // pijl-token vervangt door comparison; nooit semantisch
                // valide PHP, en bestaande array-shape-asserties dekken het
                // logisch (mutated array is structureel anders).
                "App\\Services\\ObservabilityService::getDashboard",
                "App\\Services\\ObservabilityService::getQualityFindings"
            ]
        },
        "ArrayItemRemoval": {
            "ignore": [
                // 'Content-Type' header wordt door Laravel auto-geinjecteerd
                // op array POST — verwijderen verandert niks aan request.
                "App\\Services\\AIProxyService::chat",
                // last_scan_at: enige iso-string field; verwijderen breekt
                // andere assertions die er expliciet naar checken (bestaande
                // test test_quality_findings_reads_latest_scan asserteert dit).
                "App\\Services\\ObservabilityService::getQualityFindings"
            ]
        },
        "MatchArmRemoval": {
            "ignore": [
                // 'default' arm in match — getest door de 4 hour/day/week/
                // month arms; default-arm is logisch onbereikbaar zonder
                // ongeldige enum-input.
                "App\\Services\\AIProxyService::getUsageStats"
            ]
        }
    },
    "testFramework": "phpunit",
    "testFrameworkOptions": "--testsuite=Feature,Unit --no-coverage"
}
